# ─── SERVER ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# ─── REDIS (Upstash — free at upstash.com) ──────────────────────
REDIS_URL=redis://default:YOURPASSWORD@your-upstash-url.upstash.io:6379

# ─── POSTGRES (Neon — free at neon.tech) ────────────────────────
POSTGRES_USER=your_neon_user
POSTGRES_PASSWORD=your_neon_password
POSTGRES_DB=neondb
POSTGRES_HOST=your-neon-host.neon.tech
POSTGRES_PORT=5432

# ─── TURN SERVER (Open Relay — free at metered.ca) ───────────────
TURN_SERVER_URL=turn:openrelay.metered.ca:80
TURN_SERVER_USERNAME=openrelayproject
TURN_SERVER_PASSWORD=openrelayproject

# ─── RATE LIMITING ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
